{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chrome Launcher",
  "version": "0.2.5",
  "identifier": "com.chrome-launcher.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Chrome 账号启动器",
        "width": 960,
        "height": 680,
        "minWidth": 760,
        "minHeight": 500,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}